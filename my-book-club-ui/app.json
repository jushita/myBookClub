{
  "expo": {
    "name": "myBookClub",
    "slug": "mybookclub",
    "scheme": "mybookclub",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F6F1E8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jushita.mybookclub"
    },
    "android": {
      "package": "com.jushita.mybookclub",
      "adaptiveIcon": {
        "backgroundColor": "#F6F1E8"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client"
    ]
  }
}

{
  "name": "mybookclub",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "build": "expo run:ios",
    "build:ios": "expo run:ios",
    "build:android": "expo run:android",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "node --import ../my-book-club-api/node_modules/tsx/dist/loader.mjs --test ./**/*.test.ts",
    "test:ui": "jest --config ./jest.config.js --runInBand",
    "test:ui:coverage": "jest --config ./jest.config.js --runInBand --coverage",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.8",
    "expo-crypto": "~15.0.7",
    "expo-dev-client": "~6.0.16",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.6",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  }
}

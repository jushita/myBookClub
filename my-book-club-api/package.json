{
  "name": "my-book-club-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "db:init": "tsx src/scripts/initDb.ts",
    "db:import:catalog": "tsx src/scripts/importOpenLibraryCatalog.ts",
    "db:import:authors": "tsx src/scripts/importOpenLibraryAuthors.ts",
    "db:import:editions": "tsx src/scripts/importOpenLibraryEditions.ts",
    "db:import:goodbooks": "tsx src/scripts/importGoodbooks10k.ts",
    "db:import:works": "tsx src/scripts/importOpenLibraryWorks.ts",
    "db:embed:books": "tsx src/scripts/embedBooks.ts",
    "db:psql": "tsx src/scripts/psql.ts",
    "db:repair:club-insights": "tsx src/scripts/repairClubInsights.ts",
    "db:reset:catalog": "tsx src/scripts/resetCatalog.ts",
    "db:seed": "tsx src/scripts/seedDb.ts",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
